#. Plugin Name of the plugin
#: enquire.php
msgid "Enquire - Product Enquiry Form for WooCommerce"
msgstr "Enquire - Formularz zapytań o produkt dla WooCommerce"

#. Plugin URI of the plugin
#: enquire.php
msgid "https://plogins.com/enquire/"
msgstr "https://plogins.com/enquire/"

#. Description of the plugin
#: enquire.php
msgid "Add an Ask a Question form to products that emails the store owner."
msgstr ""
"Dodaj do produktów formularz „Zadaj pytanie”, który wysyła e-mail do "
"właściciela sklepu."

#. Author of the plugin
#: enquire.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: enquire.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: enquire.php:47
msgid ""
"Enquire - Product Enquiry Form for WooCommerce requires WooCommerce to be "
"active."
msgstr ""
"Enquire - Formularz zapytań o produkt dla WooCommerce wymaga aktywnej "
"wtyczki WooCommerce."

#: src/Admin/Settings.php:52
msgid "Enquire Settings"
msgstr "Ustawienia Enquire"

#: src/Admin/Settings.php:53
msgid "Enquire"
msgstr "Enquire"

#: src/Admin/Settings.php:98
msgid "Let shoppers ask about a product before they buy"
msgstr "Pozwól klientom zapytać o produkt, zanim go kupią"

#: src/Admin/Settings.php:99
msgid ""
"Enquire adds an “Ask a question” button to your single product pages. "
"Clicking it opens an accessible form (name, email, message) that emails you "
"the question with the product details, no data is stored."
msgstr ""
"Enquire dodaje przycisk „Zadaj pytanie” na stronach pojedynczych produktów. "
"Kliknięcie otwiera dostępny formularz (imię, e-mail, wiadomość), który "
"wysyła Ci pytanie wraz ze szczegółami produktu, żadne dane nie są "
"przechowywane."

#: src/Admin/Settings.php:107
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:108
msgid "The master switch and where enquiries are delivered."
msgstr "Główny przełącznik oraz miejsce, do którego trafiają zapytania."

#: src/Admin/Settings.php:113
msgid "Enable enquiries"
msgstr "Włącz zapytania"

#: src/Admin/Settings.php:123
msgid "Show the “Ask a question” button on single product pages."
msgstr ""
"Wyświetlaj przycisk „Zadaj pytanie” na stronach pojedynczych produktów."

#: src/Admin/Settings.php:129
msgid "Recipient email"
msgstr "E-mail odbiorcy"

#: src/Admin/Settings.php:140
msgid ""
"Enquiries are emailed here. Leave empty to use your site’s admin email. The "
"customer’s address is set as Reply-To so you can reply directly."
msgstr ""
"Zapytania są wysyłane na ten adres e-mail. Pozostaw puste, aby użyć adresu "
"administratora witryny. Adres klienta jest ustawiany jako Reply-To, dzięki "
"czemu możesz odpowiedzieć bezpośrednio."

#: src/Admin/Settings.php:148
msgid "Trigger button"
msgstr "Przycisk uruchamiający"

#: src/Admin/Settings.php:149
msgid ""
"The enquiry button shown after the add-to-cart button on the product page. "
"Clear any text field below to restore its packaged default (shown as the "
"greyed hint)."
msgstr ""
"Przycisk zapytania wyświetlany po przycisku „Dodaj do koszyka” na stronie "
"produktu. Wyczyść dowolne pole tekstowe poniżej, aby przywrócić domyślne "
"ustawienie pakietu (pokazane jako wskazówka w kolorze szarym)."

#: src/Admin/Settings.php:154
msgid "Button label"
msgstr "Etykieta przycisku"

#: src/Admin/Settings.php:154
msgid ""
"The wording shoppers click to open the enquiry form, e.g. “Ask a question” "
"or “Enquire now”."
msgstr ""
"Sformułowanie, które kupujący klika, aby otworzyć formularz zapytania, np.: "
"„Zadaj pytanie” lub „Zapytaj teraz”."

#: src/Admin/Settings.php:161
msgid "Form fields"
msgstr "Pola formularza"

#: src/Admin/Settings.php:162
msgid ""
"The labels inside the enquiry dialog and which fields a shopper must "
"complete before they can send. Clear any label to restore its packaged "
"default."
msgstr ""
"Etykiety w oknie dialogowym zapytania oraz pola, które kupujący musi "
"wypełnić, zanim będzie mógł wysłać zapytanie. Wyczyść dowolną etykietę, aby "
"przywrócić jej wbudowaną wartość domyślną."

#: src/Admin/Settings.php:167
msgid "Form title"
msgstr "Tytuł formularza"

#: src/Admin/Settings.php:167
msgid ""
"The heading at the top of the dialog, set the shopper’s expectation, e.g. "
"“Ask a question about this product”."
msgstr ""
"Nagłówek znajdujący się w górnej części okna dialogowego określa oczekiwania"
" kupującego, np.: „Zadaj pytanie dotyczące tego produktu”."

#: src/Admin/Settings.php:168
msgid "Name field label"
msgstr "Etykieta pola imienia"

#: src/Admin/Settings.php:168
msgid "Sits above the name input. Customers see this wording, not “name”."
msgstr ""
"Znajduje się nad polem nazwy. Klienci widzą to sformułowanie, a nie "
"„nazwę”."

#: src/Admin/Settings.php:169
msgid "Email field label"
msgstr "Etykieta pola e-mail"

#: src/Admin/Settings.php:169
msgid ""
"Sits above the email input. This address becomes the Reply-To, so you can "
"answer the shopper directly."
msgstr ""
"Znajduje się nad polem e-mail. Adres ten staje się adresem zwrotnym, "
"dzięki czemu możesz bezpośrednio odpowiedzieć kupującemu."

#: src/Admin/Settings.php:170
msgid "Message field label"
msgstr "Etykieta pola wiadomości"

#: src/Admin/Settings.php:170
msgid ""
"Sits above the message box, prompt the kind of question you want, e.g. “Your"
" question”."
msgstr ""
"Znajduje się nad oknem wiadomości i wyświetla żądany rodzaj pytania, np.: "
"„Twoje pytanie”."

#: src/Admin/Settings.php:171
msgid "Submit button label"
msgstr "Etykieta przycisku wysyłania"

#: src/Admin/Settings.php:171
msgid "The wording on the send button inside the dialog."
msgstr "Treść przycisku wysyłania w oknie dialogowym."

#: src/Admin/Settings.php:172
msgid "Require name"
msgstr "Wymagaj imienia"

#: src/Admin/Settings.php:172
msgid "Shoppers cannot send until they fill in the name field."
msgstr "Kupujący nie mogą wysłać zapytania, dopóki nie wypełnią pola nazwy."

#: src/Admin/Settings.php:173
msgid "Require email"
msgstr "Wymagaj adresu e-mail"

#: src/Admin/Settings.php:173
msgid ""
"Shoppers cannot send without an email. A valid format is always enforced "
"when an address is entered, even if this is off, but leaving it off means "
"you may not be able to reply."
msgstr ""
"Kupujący nie mogą wysłać zapytania bez adresu e-mail. Podczas "
"wprowadzania adresu zawsze wymuszany jest prawidłowy format, nawet jeśli ta "
"opcja jest wyłączona, ale pozostawienie jej wyłączonej oznacza, że ​​możesz "
"nie być w stanie odpowiedzieć."

#: src/Admin/Settings.php:174
msgid "Require message"
msgstr "Wymagaj wiadomości"

#: src/Admin/Settings.php:174
msgid "Shoppers cannot send an empty enquiry."
msgstr "Kupujący nie mogą wysłać pustego zapytania."

#: src/Admin/Settings.php:181
msgid "Messaging"
msgstr "Komunikaty"

#: src/Admin/Settings.php:182
msgid ""
"What shoppers see after submitting, and the subject line of the email you "
"receive. Clear any field to restore its packaged default."
msgstr ""
"Co kupujący widzą po przesłaniu i temat otrzymanej wiadomości e-mail. "
"Wyczyść dowolne pole, aby przywrócić jego wartość domyślną w pakiecie."

#: src/Admin/Settings.php:187
msgid "Success message"
msgstr "Komunikat o powodzeniu"

#: src/Admin/Settings.php:187
msgid ""
"Shown inline the moment an enquiry sends, reassure the shopper and set a "
"reply expectation."
msgstr ""
"Wyświetlane w momencie wysłania zapytania, uspokój kupującego i ustal "
"oczekiwaną odpowiedź."

#: src/Admin/Settings.php:188
msgid "Error message"
msgstr "Komunikat o błędzie"

#: src/Admin/Settings.php:188
msgid ""
"Shown if the email cannot be sent (e.g. a server mail error). Keep it calm "
"and ask them to retry."
msgstr ""
"Wyświetlany, jeśli nie można wysłać wiadomości e-mail (np. błąd poczty "
"serwera). Zachowaj spokój i poproś o ponowną próbę."

#: src/Admin/Settings.php:189
msgid "Email subject"
msgstr "Temat wiadomości e-mail"

#: src/Admin/Settings.php:189
msgid ""
"The subject line of the enquiry email you receive. {product} is replaced "
"with the product name, so enquiries are easy to scan in your inbox."
msgstr ""
"Temat otrzymanej wiadomości e-mail z zapytaniem. {product} jest zastępowany "
"nazwą produktu, dzięki czemu zapytania można łatwo przeglądać w skrzynce "
"odbiorczej."

#: src/Service/EnquiryService.php:122
msgid "Your session expired. Please reload the page and try again."
msgstr "Twoja sesja wygasła. Odśwież stronę i spróbuj ponownie."

#: src/Service/EnquiryService.php:128
msgid "Please wait a moment before sending another enquiry."
msgstr "Poczekaj chwilę przed wysłaniem kolejnego zapytania."

#: src/Service/EnquiryService.php:136 src/Service/EnquiryService.php:179
msgid "Sorry, something went wrong. Please try again."
msgstr "Przepraszamy, coś poszło nie tak. Spróbuj ponownie."

#: src/Service/EnquiryService.php:199
msgid "Thanks! Your question has been sent."
msgstr "Dziękujemy! Twoje pytanie zostało wysłane."

#: src/Service/EnquiryService.php:214
msgid "Please enter your name."
msgstr "Podaj swoje imię."

#: src/Service/EnquiryService.php:219
msgid "Please enter your email address."
msgstr "Podaj swój adres e-mail."

#: src/Service/EnquiryService.php:221 src/Service/EnquiryService.php:224
msgid "Please enter a valid email address."
msgstr "Podaj poprawny adres e-mail."

#: src/Service/EnquiryService.php:228
msgid "Please enter your question."
msgstr "Wpisz swoje pytanie."

#: src/Service/EnquiryService.php:250
msgid "(not provided)"
msgstr "(nie podano)"

#. translators: %s: product name.
#: src/Service/EnquiryService.php:259
msgid "New product enquiry for: %s"
msgstr "Nowe zapytanie o produkt: %s"

#. translators: %s: customer name.
#: src/Service/EnquiryService.php:263
msgid "Name: %s"
msgstr "Imię: %s"

#. translators: %s: customer email.
#: src/Service/EnquiryService.php:265
msgid "Email: %s"
msgstr "E-mail: %s"

#: src/Service/EnquiryService.php:267
msgid "Message:"
msgstr "Wiadomość:"

#: src/Service/EnquiryService.php:268
msgid "(no message)"
msgstr "(brak wiadomości)"

#: templates/enquiry-form.php:17
msgid "Ask a question"
msgstr "Zadaj pytanie"

#: templates/enquiry-form.php:18
msgid "Ask a question about this product"
msgstr "Zadaj pytanie o ten produkt"

#: templates/enquiry-form.php:19
msgid "Your name"
msgstr "Twoje imię"

#: templates/enquiry-form.php:20
msgid "Your email"
msgstr "Twój e-mail"

#: templates/enquiry-form.php:21
msgid "Your question"
msgstr "Twoje pytanie"

#: templates/enquiry-form.php:22
msgid "Send enquiry"
msgstr "Wyślij zapytanie"

#: templates/enquiry-form.php:54
msgid "Close"
msgstr "Zamknij"

#. translators: %s: product name.
#: templates/enquiry-form.php:63
msgid "About: %s"
msgstr "Dotyczy: %s"

